PORT=3000
# Banco central de instancias
CONTROL_DB_HOST=localhost
CONTROL_DB_PORT=5432
CONTROL_DB_NAME=banco_eans
CONTROL_DB_SCHEMA=instancias
CONTROL_DB_USER=postgres
CONTROL_DB_PASSWORD=
CONTROL_DB_SSL=false
# Chave administrativa para cadastrar/listar/testar instancias
ADMIN_API_KEY=
CLIENT_DATABASE_POOL_MAX=5
CLIENT_DATABASE_POOL_IDLE_MS=30000
CLIENT_DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
CLIENT_DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Fallback legado. O caminho principal agora e o banco central de instancias.
CLIENT_API_KEYS_JSON={}
REQUEST_JSON_LIMIT=32kb
MAX_EAN_BATCH_SIZE=100
REDIS_URL=redis://127.0.0.1:6379
SYNC_INCREMENTAL_CRON=0 */2 * * *
SYNC_FULL_CRON=0 3 * * *
SYNC_INCREMENTAL_FALLBACK_HOURS=2
TRIER_PAGE_SIZE=200
TRIER_TIMEOUT_MS=30000
TRIER_DEFAULT_BASE_URL=https://api-sgf-gateway.triersistemas.com.br/sgfpod1
TRIER_REMOVE_STOCK_RESTRICTION=true
TENANT_DB_PROVISION_ENABLED=false
TENANT_DB_ADMIN_DATABASE=postgres
TENANT_DB_ADMIN_USER=
TENANT_DB_ADMIN_PASSWORD=
TENANT_DB_ADMIN_SSL=false
